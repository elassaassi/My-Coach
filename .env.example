# ── JWT ───────────────────────────────────────────────────────────────────────
# Clé HMAC-SHA384, minimum 256 bits. Générer : openssl rand -base64 64
JWT_SECRET=change-me-in-production-minimum-256-bits

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# 1. https://console.cloud.google.com → Créer projet → API & Services → Identifiants
# 2. Créer "ID client OAuth 2.0" (type: Application Web)
# 3. URI de redirection autorisés : http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── Facebook OAuth2 ───────────────────────────────────────────────────────────
# 1. https://developers.facebook.com → Mes apps → Créer une app (type: Consumer)
# 2. Ajouter le produit "Connexion Facebook"
# 3. URI de redirection OAuth valides : http://localhost:8080/login/oauth2/code/facebook
FACEBOOK_APP_ID=xxxx
FACEBOOK_APP_SECRET=xxxx

# ── Frontend URL (OAuth2 redirect après login) ────────────────────────────────
FRONTEND_URL=http://localhost:4200

# ── Base de données ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
